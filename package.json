{
  "name": "google-tracker-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
  "dev": "vite",
  "electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
  "build": "vite build",
  "desktop-build": "vite build && electron-builder",
  "preview": "vite preview",
  "lint": "eslint ."
},
  "build": {
    "appId": "com.googletracker.operations",
    "productName": "Google Tracker Operations",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "ag-grid-community": "^35.3.0",
    "ag-grid-react": "^35.3.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}